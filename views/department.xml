<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_department_tree" model="ir.ui.view">
        <field name="name">hospital_system.department.tree</field>
        <field name="model">hospital_system.department</field>
        <field name="arch" type="xml">
            <tree string="Departments">
                <field name="department_id"/>
                <field name="department_name"/>
                <field name="department_type"/>
            </tree>
        </field>
    </record>


    <!-- Form View -->
    <record id="view_department_form" model="ir.ui.view">
        <field name="name">hospital_system.department.form</field>
        <field name="model">hospital_system.department</field>
        <field name="arch" type="xml">
            <form string="Department">
                <sheet>

                    <group>
                        <field name="department_id" readonly="1"/>
                        <field name="department_name"/>
                        <field name="department_type"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>


    <!-- Action -->
    <record id="action_department" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">hospital_system.department</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>