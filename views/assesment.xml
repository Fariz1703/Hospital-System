<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hospital_assessment_tree" model="ir.ui.view">
        <field name="name">hospital.assessment.tree</field>
        <field name="model">hospital_system.assessment</field>
        <field name="arch" type="xml">

            <tree string="Assessments">
                <field name="assessment_id"/>
                <field name="appendix_number"/>
                <field name="appointment_id"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="assessment_date"/>
                <field name="state"/>
            </tree>

        </field>
    </record>


    <record id="view_hospital_assessment_form" model="ir.ui.view">
        <field name="name">hospital.assessment.form</field>
        <field name="model">hospital_system.assessment</field>
        <field name="arch" type="xml">

            <form string="Assessment">

                <header>

                    <button name="action_start"
                            type="object"
                            string="Start Assessment"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_done"
                            type="object"
                            string="Complete"
                            class="btn-success"
                            invisible="state != 'in_progress'"/>

                    <button name="action_cancel"
                            type="object"
                            string="Cancel"
                            class="btn-danger"
                            invisible="state in ('done','cancel')"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,in_progress,done"/>

                </header>


                <sheet>

                    <group>
                        <group>
                            <field name="assessment_id" readonly="1"/>
                            <field name="appointment_id" readonly="state != 'in_progress'"/>
                            <field name="assessment_date" readonly="state != 'in_progress'"/>
                        </group>

                        <group>
                            <field name="patient_id" readonly="1"/>
                            <field name="doctor_id" readonly="1"/>
                        </group>
                    </group>

                    <group string="Vital Signs">

                        <group>
                            <field name="temperature" readonly="state != 'in_progress'"/>
                            <field name="blood_pressure" readonly="state != 'in_progress'"/>
                            <field name="heart_rate" readonly="state != 'in_progress'"/>
                        </group>

                        <group>
                            <field name="respiratory_rate" readonly="state != 'in_progress'"/>
                            <field name="weight" readonly="state != 'in_progress'"/>
                            <field name="height" readonly="state != 'in_progress'"/>
                        </group>

                    </group>


                    <group string="Medical Assessment">

                        <field name="chief_complaint" readonly="state != 'in_progress'"/>

                        <field name="diagnosis" readonly="state != 'in_progress'"/>

                        <field name="treatment_plan" readonly="state != 'in_progress'"/>

                        <field name="notes" readonly="state != 'in_progress'"/>

                    </group>


                    <field name="service_line_ids" readonly="state != 'in_progress'">
                        <tree editable="bottom">
                            <field name="service_id"/>
                            <field name="quantity"/>
                            <field name="price"/>
                            <field name="subtotal"/>
                        </tree>
                    </field>

                </sheet>


                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>

        </field>
    </record>


    <record id="view_hospital_assessment_search" model="ir.ui.view">
        <field name="name">hospital.assessment.search</field>
        <field name="model">hospital_system.assessment</field>
        <field name="arch" type="xml">

            <search>

                <field name="assessment_id"/>
                <field name="appendix_number"/>
                <field name="appointment_id"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="assessment_date"/>
                <field name="state"/>

                <filter
                    name="draft"
                    string="Draft"
                    domain="[('state','=','draft')]"
                />

                <filter
                    name="in_progress"
                    string="In Progress"
                    domain="[('state','=','in_progress')]"
                />

                <filter
                    name="done"
                    string="Done"
                    domain="[('state','=','done')]"
                />

                <group expand="0" string="Group By">

                    <filter
                        name="group_doctor"
                        string="Doctor"
                        context="{'group_by':'doctor_id'}"
                    />

                    <filter
                        name="group_date"
                        string="Assessment Date"
                        context="{'group_by':'assessment_date'}"
                    />

                    <filter
                        name="group_patient"
                        string="Patient"
                        context="{'group_by':'patient_id'}"
                    />

                </group>

            </search>

        </field>
    </record>


    <record id="action_hospital_assessment" model="ir.actions.act_window">
        <field name="name">Assessments</field>
        <field name="res_model">hospital_system.assessment</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_hospital_assessment_search"/>
    </record>

</odoo>