<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_patient_registration_tree" model="ir.ui.view">
        <field name="name">hospital_system.patient_registration.tree</field>
        <field name="model">hospital_system.patient</field>
        <field name="arch" type="xml">
            <tree string="Patients">
                <field name="patient_id"/>
                <field name="patient_name"/>
                <field name="identity_number"/>
                <field name="gender"/>
                <field name="birth_date"/>
                <field name="age"/>
                <field name="phone"/>
                <field name="blood_type"/>
            </tree>
        </field>
    </record>


    <record id="view_patient_registration_form" model="ir.ui.view">
        <field name="name">hospital_system.patient_registration.form</field>
        <field name="model">hospital_system.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">


                <header>

                    <button name="action_make_appointment"
                            type="object"
                            string="Confirm"
                            class="btn-primary"/>
                </header> 

                <sheet>

                    <group>
                        <group>
                            <field name="patient_id" readonly="1"/>
                            <field name="patient_name"/>
                            <field name="identity_number"/>
                            <field name="gender"/>
                            <field name="birth_date"/>
                            <field name="age" readonly="1"/>
                        </group>

                        <group>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="blood_type"/>
                        </group>
                    </group>

                    <group string="Address">
                        <field name="address"/>
                    </group>

                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>


            </form>
        </field>
    </record>

    <record id="view_patient_registration_search" model="ir.ui.view">
        <field name="name">hospital_system.patient_registration.search</field>
        <field name="model">hospital_system.patient</field>
        <field name="arch" type="xml">

            <search>

                <field name="patient_id"/>
                <field name="patient_name"/>
                <field name="identity_number"/>
                <field name="gender"/>
                <field name="birth_date"/>
                <field name="age"/>
                <field name="phone"/>
                <field name="blood_type"/>

                <filter
                    name="male"
                    string="Male"
                    domain="[('gender','=','male')]"
                />

                <filter
                    name="female"
                    string="Female"
                    domain="[('gender','=','female')]"
                />

                <group expand="0" string="Group By">

                    <filter
                        name="group_gender"
                        string="Gender"
                        context="{'group_by':'gender'}"
                    />

                    <filter
                        name="group_blood_type"
                        string="Blood Type"
                        context="{'group_by':'blood_type'}"
                    />

                </group>

            </search>

        </field>
    </record>

    <record id="action_patient_registration" model="ir.actions.act_window">
        <field name="name">Patients Registration</field>
        <field name="res_model">hospital_system.patient</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_patient_registration_search"/>
    </record>

</odoo>