<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_patient_registration_tree" model="ir.ui.view">
        <field name="name">hospital_system.patient_registration.tree</field>
        <field name="model">hospital_system.patient</field>
        <field name="arch" type="xml">
            <tree string="Patients">
                <field name="patient_id"/>
                <field name="patient_name"/>
                <field name="identity_number"/>
                <field name="gender"/>
                <field name="birth_date"/>
                <field name="age"/>
                <field name="phone"/>
                <field name="blood_type"/>
            </tree>
        </field>
    </record>


    <!-- Form View -->
    <record id="view_patient_registration_form" model="ir.ui.view">
        <field name="name">hospital_system.patient_registration.form</field>
        <field name="model">hospital_system.patient</field>
        <field name="arch" type="xml">
<form string="Patient">


    <header>

        <button name="action_make_appointment"
                type="object"
                string="Confirm"
                class="btn-primary"/>
    </header> 

    <sheet>

        <group>
            <group>
                <field name="patient_id" readonly="1"/>
                <field name="patient_name"/>
                <field name="identity_number"/>
                <field name="gender"/>
                <field name="birth_date"/>
                <field name="age" readonly="1"/>
            </group>

            <group>
                <field name="phone"/>
                <field name="email"/>
                <field name="blood_type"/>
            </group>
        </group>

        <group string="Address">
            <field name="address"/>
        </group>

    </sheet>

    <chatter/>

</form>
        </field>
    </record>


    <!-- Action -->
    <record id="action_patient_registration" model="ir.actions.act_window">
        <field name="name">Patients Registration</field>
        <field name="res_model">hospital_system.patient</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>