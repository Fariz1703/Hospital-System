<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_doctor_tree" model="ir.ui.view">
        <field name="name">hospital_system.doctor.tree</field>
        <field name="model">hospital_system.doctor</field>
        <field name="arch" type="xml">
            <tree>
                <field name="doctor_id"/>
                <field name="doctor_name"/>
                <field name="gender"/>
                <field name="appendix"/>
                <field name="department_id"/>
            </tree>
        </field>
    </record>


    <record id="view_doctor_form" model="ir.ui.view">
        <field name="name">hospital_system.doctor.form</field>
        <field name="model">hospital_system.doctor</field>
        <field name="arch" type="xml">
            <form string="Doctor">
                <sheet>
                    <h1>
                        <field name="doctor_id" readonly="1"/>
                    </h1>
                    <group>
                        <group>
                            
                            <field name="doctor_name"/>
                            <field name="gender"/>
                        </group>
                        <group>
                            <field name="appendix"/>
                            <field name="department_id"
                                domain="[('department_type','=','medical')]"/>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>


    <record id="view_doctor_search" model="ir.ui.view">
        <field name="name">hospital_system.doctor.search</field>
        <field name="model">hospital_system.doctor</field>
        <field name="arch" type="xml">

            <search>

                <field name="doctor_id"/>
                <field name="doctor_name"/>
                <field name="gender"/>
                <field name="appendix"/>
                <field name="department_id"/>

                <filter
                    name="male"
                    string="Male"
                    domain="[('gender','=','male')]"
                />

                <filter
                    name="female"
                    string="Female"
                    domain="[('gender','=','female')]"
                />

                <group expand="0" string="Group By">

                    <filter
                        name="group_department"
                        string="Department"
                        context="{'group_by':'department_id'}"
                    />

                    <filter
                        name="group_gender"
                        string="Gender"
                        context="{'group_by':'gender'}"
                    />

                </group>

            </search>

        </field>
    </record>


    <record id="action_doctor" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hospital_system.doctor</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_doctor_search"/>
    </record>
</odoo>