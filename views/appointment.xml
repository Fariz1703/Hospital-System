<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hospital_appointment_tree" model="ir.ui.view">
        <field name="name">hospital.appointment.tree</field>
        <field name="model">hospital_system.appointment</field>
        <field name="arch" type="xml">
            <tree string="Appointments">
                <field name="appointment_id"/>
                <field name="patient_id"/>
                <field name="appointment_date"/>
                <field name="department_id"/>
                <field name="doctor_id"/>
                <field name="appendix_number"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_hospital_appointment_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital_system.appointment</field>
        <field name="arch" type="xml">

            <form string="Appointment">

                <header>

                    <button
                        name="action_confirm"
                        type="object"
                        string="Confirm"
                        class="btn-primary"
                        invisible="state != 'draft'"
                    />

                    <button
                        name="action_checkin"
                        type="object"
                        string="Check In"
                        class="btn-primary"
                        invisible="state != 'confirmed'"
                    />

                    <button
                        name="action_cancel"
                        type="object"
                        string="Cancel"
                        class="btn-danger"
                        invisible="state == 'done' or state == 'cancel'"
                    />

                    <button name="action_print_queue"
                        type="object"
                        string="Print Queue Ticket"
                        class="btn-info"
                        invisible="state != 'checkin'"
                    />

                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,confirmed,checkin,in_consultation,done"
                    />

                </header>

                <sheet>

                    <h1>
                        <field name="appointment_id" readonly="1"/>
                    </h1>

                    <h2>
                        <field name="appendix_number" readonly="1"/>
                    </h2>

                    <group>
                        <group>
                            <field name="patient_id" readonly='1'/>
                            <field name="appointment_date" readonly="state != 'draft'"/>
                        </group>

                        <group>
                            <field name="department_id" readonly="state != 'draft'"/>
                            <field
                                name="doctor_id"
                                domain="[('department_id','=',department_id)]"
                                readonly="state != 'draft'"
                            />
                        </group>
                    </group>
                    <hr/>
                    <group>
                        <field name="chief_complaint" readonly="state != 'draft'"/>
                    </group>

                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>

        </field>
    </record>

    <record id="view_hospital_appointment_search" model="ir.ui.view">
        <field name="name">hospital.appointment.search</field>
        <field name="model">hospital_system.appointment</field>
        <field name="arch" type="xml">

            <search>

                <field name="appointment_id"/>
                <field name="patient_id"/>
                <field name="appointment_date"/>
                <field name="department_id"/>
                <field name="doctor_id"/>
                <field name="appendix_number"/>
                <field name="state"/>

                <filter
                    name="today"
                    string="Today"
                    domain="[('appointment_date','=',context_today())]"
                />

                <filter
                    name="checkin"
                    string="Checked In"
                    domain="[('state','=','checkin')]"
                />

                <filter
                    name="done"
                    string="Done"
                    domain="[('state','=','done')]"
                />

                <group expand="0" string="Group By">

                    <filter
                        name="group_doctor"
                        string="Doctor"
                        context="{'group_by':'doctor_id'}"
                    />

                    <filter
                        name="group_date"
                        string="Appointment Date"
                        context="{'group_by':'appointment_date'}"
                    />

                </group>

            </search>

        </field>
    </record>

    <record id="action_hospital_appointment" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">hospital_system.appointment</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_hospital_appointment_search"/>
    </record>

</odoo>