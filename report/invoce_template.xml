<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="report_hospital_invoice">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">

                        <div class="page">

                            <!-- Header -->
                            <h2 style="text-align:center;">Hospital Invoice</h2>

                            <table style="width:100%; margin-top:20px;">
                                <tr>
                                    <td>
                                        <strong>Invoice :</strong>
                                        <span t-field="doc.invoice_id"/>
                                    </td>
                                    <td style="text-align:right;">
                                        <strong>Date :</strong>
                                        <span t-field="doc.invoice_date"/>
                                    </td>
                                </tr>
                            </table>

                            <br/>

                            <!-- Patient Info -->
                            <table style="width:100%;">
                                <tr>
                                    <td><strong>Patient</strong></td>
                                    <td>:</td>
                                    <td><span t-field="doc.patient_id.patient_name"/></td>
                                </tr>

                                <tr>
                                    <td><strong>Doctor</strong></td>
                                    <td>:</td>
                                    <td><span t-field="doc.doctor_id.doctor_name"/></td>
                                </tr>
                            </table>

                            <br/>

                            <!-- Service Table -->
                            <table class="table table-bordered" style="width:100%;">
                                <thead>
                                    <tr>
                                        <th>No</th>
                                        <th>Service</th>
                                        <th>Qty</th>
                                        <th>Price</th>
                                        <th>Subtotal</th>
                                    </tr>
                                </thead>

                                <tbody>

                                    <t t-set="i" t-value="1"/>

                                    <t t-foreach="doc.invoice_line_ids" t-as="line">
                                        <tr>

                                            <td>
                                                <span t-esc="i"/>
                                                <t t-set="i" t-value="i + 1"/>
                                            </td>

                                            <td>
                                                <span t-field="line.service_id.service_name"/>
                                            </td>

                                            <td>
                                                <span t-field="line.quantity"/>
                                            </td>

                                            <td>
                                                <span t-esc="'Rp {:,.0f}'.format(line.price)"/>
                                            </td>

                                            <td>
                                                <span t-esc="'Rp {:,.0f}'.format(line.subtotal)"/>
                                            </td>

                                        </tr>
                                    </t>

                                </tbody>

                                <tfoot>
                                    <tr>
                                        <td colspan="4" style="text-align:right;">
                                            <strong>Total</strong>
                                        </td>

                                        <td>
                                            <strong>
                                                <span t-esc="'Rp {:,.0f}'.format(doc.total_amount)"/>
                                            </strong>
                                        </td>
                                    </tr>
                                </tfoot>

                            </table>

                            <br/><br/>

                            <p style="text-align:center;">
                                Thank you for visiting our hospital
                            </p>

                        </div>

                    </t>
                </t>
            </t>
        </template>

    </data>
</odoo>